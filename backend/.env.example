# =================================================================
# .env  –  Environment Variables for CampusBot
# Copy this file to .env and fill in YOUR values.
# NEVER commit .env to GitHub!
# =================================================================

PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/campusbot
# Atlas: MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/campusbot

# JWT Secrets (use long random strings!)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_long_random_string_for_users
JWT_ADMIN_SECRET=change_this_different_long_string_for_admins
JWT_EXPIRES=7d
JWT_ADMIN_EXPIRES=1d

# Admin Registration Key (required to create admin accounts)
ADMIN_REGISTRATION_KEY=campusadmin2024_secretkey
SUPER_ADMIN_KEY=super_secret_key_for_superadmin_only

# Default Admin (auto-created on first run)
DEFAULT_ADMIN_NAME=CampusBot Admin
DEFAULT_ADMIN_EMAIL=admin@college.edu
DEFAULT_ADMIN_PASS=Admin@1234
